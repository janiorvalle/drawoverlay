#!/bin/sh
set -eu

if command -v gitleaks >/dev/null 2>&1; then
  exec gitleaks git --pre-commit --redact --staged
fi

if [ -x /opt/homebrew/bin/gitleaks ]; then
  exec /opt/homebrew/bin/gitleaks git --pre-commit --redact --staged
fi

echo "gitleaks is required for commits. Install it from https://github.com/gitleaks/gitleaks." >&2
exit 1
