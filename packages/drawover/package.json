{
  "name": "drawoverlay",
  "version": "0.1.0",
  "description": "A development overlay for precise UI review",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/janiorvalle/drawoverlay.git"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./contracts": {
      "types": "./dist/contracts/index.d.ts",
      "import": "./dist/contracts/index.js"
    },
    "./coordinates": {
      "types": "./dist/coordinates.d.ts",
      "import": "./dist/coordinates.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node -e \"fs.rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "vitest run src",
    "test:package": "publint --strict && attw --pack . --profile esm-only"
  },
  "dependencies": {
    "html-to-image": "1.11.13"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.4",
    "publint": "0.3.21"
  }
}
