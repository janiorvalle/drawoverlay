{
  "name": "drawover-workspace",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "build": "pnpm -r --workspace-concurrency=1 build",
    "typecheck": "pnpm --filter drawover build && pnpm -r typecheck",
    "lint": "eslint . && prettier --check . && node scripts/verify-architecture.mjs",
    "test": "vitest run",
    "test:e2e": "pnpm --filter drawover build && playwright test",
    "test:prod-strip": "pnpm --filter drawover build && node scripts/verify-prod-strip.mjs",
    "size": "pnpm --filter drawover build && size-limit",
    "test:pack": "pnpm --filter drawover build && node scripts/verify-pack.mjs",
    "verify:architecture": "node scripts/verify-architecture.mjs",
    "verify": "pnpm build && pnpm typecheck && pnpm lint && pnpm test && pnpm test:e2e && pnpm test:prod-strip && pnpm size && pnpm test:pack",
    "dev": "pnpm --filter drawover build && pnpm --filter @drawover/playground dev",
    "prepare": "node scripts/install-hooks.mjs"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@size-limit/esbuild": "12.1.0",
    "@size-limit/file": "12.1.0",
    "@types/node": "26.1.1",
    "eslint": "10.0.1",
    "globals": "17.7.0",
    "happy-dom": "20.10.6",
    "prettier": "3.9.4",
    "size-limit": "12.1.0",
    "typescript": "6.0.2",
    "typescript-eslint": "8.63.0",
    "vite": "8.1.3",
    "vitest": "4.1.10"
  },
  "size-limit": [
    {
      "name": "drawover main entry",
      "path": "packages/drawover/dist/index.js",
      "import": "{ init }",
      "limit": "75 kB"
    }
  ]
}
