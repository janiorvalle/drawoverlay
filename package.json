{
  "name": "drawover-workspace",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "build": "pnpm -r --workspace-concurrency=1 build",
    "typecheck": "pnpm --filter drawoverlay build && pnpm -r typecheck",
    "lint": "eslint . && prettier --check . && node scripts/verify-architecture.mjs && node scripts/verify-dependencies.mjs && node scripts/verify-infra.mjs",
    "test": "vitest run",
    "test:e2e": "pnpm --filter drawoverlay build && node scripts/build-preview-fixtures.mjs && playwright test",
    "test:prod-strip": "pnpm --filter drawoverlay build && node scripts/verify-prod-strip.mjs",
    "size": "pnpm --filter drawoverlay build && size-limit",
    "test:pack": "pnpm --filter drawoverlay build && node scripts/verify-pack.mjs && pnpm --filter drawoverlay test:package",
    "verify:architecture": "node scripts/verify-architecture.mjs",
    "verify:dependencies": "node scripts/verify-dependencies.mjs",
    "verify:infra": "node scripts/verify-infra.mjs",
    "verify": "pnpm build && pnpm typecheck && pnpm lint && pnpm test && pnpm test:e2e && pnpm test:prod-strip && pnpm size && pnpm test:pack",
    "dev": "pnpm --filter drawoverlay build && pnpm --filter @drawover/playground dev",
    "prepare": "node scripts/install-hooks.mjs"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@changesets/cli": "2.31.0",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@size-limit/esbuild": "12.1.0",
    "@size-limit/file": "12.1.0",
    "@types/node": "26.1.1",
    "eslint": "10.6.0",
    "globals": "17.7.0",
    "happy-dom": "20.10.6",
    "prettier": "3.9.4",
    "size-limit": "12.1.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vite": "8.1.4",
    "vitest": "4.1.10",
    "yaml": "2.9.0"
  },
  "size-limit": [
    {
      "name": "drawoverlay main entry",
      "path": "packages/drawover/dist/index.js",
      "import": "{ init }",
      "gzip": true,
      "limit": "75 kB"
    }
  ]
}
